rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /energy_events/{eventId} {
      allow read, write: if true;
    }
    match /system_config/{configId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
